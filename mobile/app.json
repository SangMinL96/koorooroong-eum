{
  "expo": {
    "name": "꾸루룽음",
    "slug": "koorooroong-eum",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "koorooroongeum",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.koorooroongeum.app"
    },
    "android": {
      "package": "com.koorooroongeum.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "bd387760-3d15-47fe-9651-f50e828a19af"
      }
    }
  }
}
