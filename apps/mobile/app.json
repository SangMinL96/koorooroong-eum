{
  "expo": {
    "name": "꾸루룽음",
    "slug": "koorooroong-eum",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "koorooroongeum",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.koorooroongeum.app"
    },
    "android": {
      "package": "com.koorooroongeum.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
